<Window x:Class="rezervacka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:rezervacka"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBox HorizontalAlignment="Left" Margin="46,30,0,0" TextWrapping="Wrap" Text="Výběr filmu" VerticalAlignment="Top" Width="120"/>
        <ComboBox x:Name="cmbFilms" HorizontalAlignment="Left" Margin="46,53,0,0" VerticalAlignment="Top" Width="120">
            <ComboBoxItem Content="Fight club"/>
            <ComboBoxItem Content="Borat"/>
            <ComboBoxItem Content="Interstellar"/>
            <ComboBoxItem Content="Babovřesky"/>
        </ComboBox>
        <TextBox HorizontalAlignment="Left" Margin="46,168,0,0" TextWrapping="Wrap" Text="Doplňky" VerticalAlignment="Top" Width="120"/>
        <TextBox HorizontalAlignment="Left" Margin="46,88,0,0" TextWrapping="Wrap" Text="Typ sedadla" VerticalAlignment="Top" Width="120"/>

        <RadioButton x:Name="rbStandard" Content="Standard" HorizontalAlignment="Left" Margin="46,140,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="rbPremium" Content="Premium" HorizontalAlignment="Left" Margin="46,120,0,0" VerticalAlignment="Top"/>

        <CheckBox x:Name="cbDrink" Content="Nápoj" HorizontalAlignment="Left" Margin="46,238,0,0" VerticalAlignment="Top"/>
        <CheckBox x:Name="cbFood" Content="Nachos" HorizontalAlignment="Left" Margin="46,218,0,0" VerticalAlignment="Top"/>
        <CheckBox x:Name="cbGlasses" Content="3D Brýle" HorizontalAlignment="Left" Margin="46,198,0,0" VerticalAlignment="Top"/>

        <Button x:Name="btnReservation" Content="Vytvoř rezervaci" HorizontalAlignment="Left" Margin="46,270,0,0" VerticalAlignment="Top" Width="120" Click="btnReservation_Click"/>

    </Grid>
</Window>
